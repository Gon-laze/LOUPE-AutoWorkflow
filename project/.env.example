# ===============================
# AutoWorkFlow Environment Config
# ===============================

# REQUIRED BEFORE START:
# 1) Fill API keys for at least one provider.
# 2) Confirm proxy mode matches selected provider.
# 3) Review host/port/runtime paths for your server.

# Application identity and network bind
APP_NAME=AutoWorkFlow Service
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://localhost:8000

# Runtime storage locations
# RUNTIME_DIR: base path for runtime artifacts (uploads/reports/kb)
# DB_PATH: sqlite database path
# LOG_DIR: application log directory
RUNTIME_DIR=./runtime
DB_PATH=./runtime/db/autoworkflow.db
LOG_DIR=./runtime/logs

# Logging and maintenance
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=14
JOB_RETENTION_DAYS=30
MAINTENANCE_INTERVAL_SEC=3600

# OpenAI provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic provider
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Zhipu provider
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZHIPU_MODEL=glm-4.5-flash

# Proxy policy on this server:
# 1) OpenAI / Anthropic: enable proxy before start
#    source ~/.bashrc_ProxyUse
# 2) Zhipu: disable proxy before start
#    source ~/.bashrc_ProxyWithdraw
